      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/investor-questionnaire",
      "destination": "https://portal.rebeldividends.com/apply",
      "statusCode": 307,
      "regex": "^(?!/_next)/investor-questionnaire(?:/)?$"
    },
    {
      "source": "/sophisticated-investor-questionnaire",
      "destination": "https://portal.rebeldividends.com/apply",
      "statusCode": 307,
      "regex": "^(?!/_next)/sophisticated-investor-questionnaire(?:/)?$"
    }
  ],
